DB_TYPE=sqlite
# Für MariaDB / MySQL, kommentiere die obere Zeile aus und passe diese an:
# DB_TYPE=mariadb
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=echo
# DB_PASS=secret
# DB_NAME=echo_db

PORT=3001
NODE_ENV=development

# Sicherheit: Erlaubt Demo-Rollen-Auswahl bei Registrierung (für lokale Tests).
# Im Produktivbetrieb weglassen oder auf 'false' setzen. Erste Registrierung wird dann Admin,
# alle folgenden User werden 'guest'.
ALLOW_DEMO_ROLES=false

# LDAP / Active Directory Integration (optional)
# LDAP_URL=ldap://localhost:389
# LDAP_BASE_DN=dc=example,dc=org
# LDAP_BIND_DN=cn=admin,dc=example,dc=org
# LDAP_BIND_PASSWORD=secret
# LDAP_IS_AD=false
# LDAP_ROLE_MAPPING={"ShirAsal-Admins": "admin", "ShirAsal-Members": "member"}
